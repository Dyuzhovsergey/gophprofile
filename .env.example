# Адрес HTTP-сервера GophProfile.
GOPHPROFILE_SERVER_ADDRESS=:8080

# Уровень логирования: debug, info, warn, error.
GOPHPROFILE_LOG_LEVEL=info

# DSN подключения к PostgreSQL.
GOPHPROFILE_DATABASE_DSN=postgres://YOUR_USER:YOUR_PASSWORD@localhost:5432/gophprofile?sslmode=disable

# =========================
# MinIO / S3
# =========================

# Endpoint S3-совместимого хранилища.
# Для локального MinIO обычно используется http://localhost:9000.
GOPHPROFILE_S3_ENDPOINT=http://localhost:9000

# Регион нужен AWS SDK. Для MinIO обычно достаточно us-east-1.
GOPHPROFILE_S3_REGION=us-east-1

# Доступы к MinIO.
GOPHPROFILE_S3_ACCESS_KEY=minioadmin
GOPHPROFILE_S3_SECRET_KEY=minioadmin

# Bucket для хранения аватарок.
GOPHPROFILE_S3_BUCKET=avatars

# Для локального MinIO обычно нужен path-style доступ.
GOPHPROFILE_S3_USE_PATH_STYLE=true

# Максимальный размер загружаемого файла в байтах.
# 10485760 байт = 10 MB.
GOPHPROFILE_MAX_UPLOAD_SIZE_BYTES=10485760


# =========================
# RabbitMQ
# =========================

# URL подключения к RabbitMQ.
GOPHPROFILE_RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Exchange для событий аватарок.
GOPHPROFILE_RABBITMQ_EXCHANGE=avatars.exchange

# Queue и routing key для события avatar.uploaded.
GOPHPROFILE_RABBITMQ_UPLOAD_QUEUE=avatar.uploaded.queue
GOPHPROFILE_RABBITMQ_UPLOAD_ROUTING_KEY=avatar.uploaded

# Queue и routing key для события avatar.deleted.
GOPHPROFILE_RABBITMQ_DELETE_QUEUE=avatar.deleted.queue
GOPHPROFILE_RABBITMQ_DELETE_ROUTING_KEY=avatar.deleted




# =========================
# Application
# =========================

GOPHPROFILE_SERVER_ADDRESS=localhost:9090
GOPHPROFILE_LOG_LEVEL=debug
GOPHPROFILE_MAX_UPLOAD_SIZE_BYTES=10485760

# =========================
# PostgreSQL
# =========================

GOPHPROFILE_DATABASE_DSN=postgres://gophprofile:gophprofile@localhost:5433/gophprofile?sslmode=disable

# =========================
# MinIO / S3
# =========================

GOPHPROFILE_S3_ENDPOINT=http://localhost:9000
GOPHPROFILE_S3_REGION=us-east-1
GOPHPROFILE_S3_ACCESS_KEY=minioadmin
GOPHPROFILE_S3_SECRET_KEY=minioadmin
GOPHPROFILE_S3_BUCKET=avatars
GOPHPROFILE_S3_USE_PATH_STYLE=true

# =========================
# RabbitMQ
# =========================

GOPHPROFILE_RABBITMQ_URL=amqp://guest:guest@localhost:5672/
GOPHPROFILE_RABBITMQ_EXCHANGE=avatars.exchange

GOPHPROFILE_RABBITMQ_UPLOAD_QUEUE=avatar.uploaded.queue
GOPHPROFILE_RABBITMQ_UPLOAD_ROUTING_KEY=avatar.uploaded

GOPHPROFILE_RABBITMQ_DELETE_QUEUE=avatar.deleted.queue
GOPHPROFILE_RABBITMQ_DELETE_ROUTING_KEY=avatar.deleted
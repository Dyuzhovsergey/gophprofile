        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Messages unacked",
      "id": 13,
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rabbitmq_detailed_queue_messages_unacked{queue=~\"avatar\\\\.(uploaded|deleted)\\\\.queue\"})",
          "legendFormat": "unacked",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {

{
  "uid": "gophprofile-worker-queue",
  "title": "GophProfile Worker & Queue",
  "tags": ["gophprofile", "worker", "rabbitmq"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "RabbitMQ queue depth",
      "id": 1,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (queue) (rabbitmq_detailed_queue_messages{queue=~\"avatar\\\\.(uploaded|deleted)\\\\.queue\"})",
          "legendFormat": "{{queue}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "RabbitMQ ready / unacked messages",
      "id": 2,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (queue) (rabbitmq_detailed_queue_messages_ready{queue=~\"avatar\\\\.(uploaded|deleted)\\\\.queue\"})",
          "legendFormat": "ready {{queue}}",
          "refId": "A"
        },
        {
          "expr": "sum by (queue) (rabbitmq_detailed_queue_messages_unacked{queue=~\"avatar\\\\.(uploaded|deleted)\\\\.queue\"})",
          "legendFormat": "unacked {{queue}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "RabbitMQ consumers",
      "id": 3,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (queue) (rabbitmq_detailed_queue_consumers{queue=~\"avatar\\\\.(uploaded|deleted)\\\\.queue\"})",
          "legendFormat": "{{queue}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Worker processing rate",
      "id": 4,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (event_type, status) (rate(gophprofile_worker_messages_consumed_total[5m]))",
          "legendFormat": "{{event_type}} {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Worker failed messages rate",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (event_type) (rate(gophprofile_worker_messages_failed_total[5m]))",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Worker processing duration p95",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, event_type, status) (rate(gophprofile_worker_processing_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{event_type}} {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Avatar processing duration p95",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, status) (rate(gophprofile_avatars_processing_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Avatar processing rate",
      "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (status) (rate(gophprofile_avatars_processing_total[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Active worker jobs",
      "id": 9,
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(gophprofile_worker_active_jobs)",
          "legendFormat": "active jobs",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Worker failed messages total",
      "id": 10,
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(gophprofile_worker_messages_failed_total)",
          "legendFormat": "failed messages",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Worker retries total",
      "id": 11,

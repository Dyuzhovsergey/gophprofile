      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rabbitmq_detailed_queue_consumers{queue=~\"avatar\\\\.(uploaded|deleted)\\\\.queue\"})",
          "legendFormat": "consumers",

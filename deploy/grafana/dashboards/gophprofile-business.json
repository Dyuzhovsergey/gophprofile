      "id": 10,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, status) (rate(gophprofile_avatars_processing_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{status}}",
          "refId": "A"
        }
      ]
    },
    {

      "id": 14,
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(gophprofile_avatars_uploads_total{status=\"success\"}[30m])) / clamp_min(sum(increase(gophprofile_avatars_uploads_total[30m])), 1)",

      "id": 4,
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pg_stat_database_numbackends{datname=\"gophprofile\"}",
          "legendFormat": "connections",
          "refId": "A"

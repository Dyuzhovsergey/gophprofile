      "targets": [
        {
          "expr": "sum by (queue) (rabbitmq_detailed_queue_messages{queue=~\"avatar\\\\.(uploaded|deleted)\\\\.queue\"})",
          "legendFormat": "{{queue}}",
          "refId": "A"
        }
      ]
    },
    {

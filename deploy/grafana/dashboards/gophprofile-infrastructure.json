      "type": "timeseries",
      "title": "PostgreSQL transactions rate",
      "id": 6,
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=\"gophprofile\"}[5m])",
          "legendFormat": "commits",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname=\"gophprofile\"}[5m])",
          "legendFormat": "rollbacks",
          "refId": "B"
        }
      ]
    },
    {

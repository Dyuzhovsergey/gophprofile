{
  "uid": "gophprofile-overview",
  "title": "GophProfile Service Overview",
  "tags": ["gophprofile", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP request rate",
      "id": 1,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (method, route, status) (rate(gophprofile_http_requests_total[5m]))",
          "legendFormat": "{{method}} {{route}} {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP error rate",
      "id": 2,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(gophprofile_http_requests_total{status=~\"5..\"}[5m]))",
          "legendFormat": "5xx errors",
          "refId": "A"
        },
        {
          "expr": "sum(rate(gophprofile_http_requests_total{status=~\"4..\"}[5m]))",
          "legendFormat": "4xx errors",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP p95 latency",
      "id": 3,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(gophprofile_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total uploads",
      "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(gophprofile_avatars_uploads_total{status=\"success\"})",
          "legendFormat": "successful uploads",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Upload errors",
      "id": 5,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(gophprofile_avatars_uploads_total{status=\"error\"})",
          "legendFormat": "upload errors",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "timeseries",
      "title": "Avatar upload duration p95",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, status) (rate(gophprofile_avatars_upload_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Worker processed messages",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (event_type, status) (rate(gophprofile_worker_messages_consumed_total[5m]))",
          "legendFormat": "{{event_type}} {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Worker failed messages",
      "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (event_type) (rate(gophprofile_worker_messages_failed_total[5m]))",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Worker processing p95",
      "id": 9,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, event_type, status) (rate(gophprofile_worker_processing_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{event_type}} {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Approx storage bytes",
      "id": 10,
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "gophprofile_avatars_storage_bytes",
          "legendFormat": "storage bytes",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Active worker jobs",
      "id": 11,
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(gophprofile_worker_active_jobs)",
          "legendFormat": "active jobs",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Deleted avatars",
      "id": 12,
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(gophprofile_avatars_deleted_total{status=\"success\"})",
          "legendFormat": "deleted avatars",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    }
  ]
}